<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.mentalcare.mapper.DiaryMapper">

    <resultMap id="DiaryResultMap" type="Diary">
        <id     property="id"              column="id"/>
        <result property="recordDate"      column="record_date"/>
        <result property="wakeTime"        column="wake_time"/>
        <result property="sleepDuration"   column="sleep_duration"/>
        <result property="appliedCompany"  column="applied_company"/>
        <result property="moodScore"       column="mood_score"/>
        <result property="memo"            column="memo"/>
        <result property="createdAt"       column="created_at"/>
    </resultMap>

    <insert id="insert" parameterType="Diary">
        INSERT INTO diary (record_date, wake_time, sleep_duration, applied_company, mood_score, memo)
        VALUES (#{recordDate}, #{wakeTime}, #{sleepDuration}, #{appliedCompany}, #{moodScore}, #{memo})
    </insert>

    <select id="findByDate" resultMap="DiaryResultMap">
        SELECT * FROM diary WHERE record_date = #{recordDate}
    </select>

    <select id="findAll" resultMap="DiaryResultMap">
        SELECT * FROM diary ORDER BY record_date DESC
    </select>

    <select id="findRecent" resultMap="DiaryResultMap">
        SELECT * FROM diary ORDER BY record_date DESC LIMIT #{limit}
    </select>

    <update id="update" parameterType="Diary">
        UPDATE diary
        SET wake_time       = #{wakeTime},
            sleep_duration  = #{sleepDuration},
            applied_company = #{appliedCompany},
            mood_score      = #{moodScore},
            memo            = #{memo}
        WHERE record_date = #{recordDate}
    </update>

    <delete id="deleteByDate">
        DELETE FROM diary WHERE record_date = #{recordDate}
    </delete>

</mapper>
